{
  "extends": "./.wxt/tsconfig.json",
  "compilerOptions": {
    "target": "ES2021",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ES2021", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": false,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "types": ["chrome"],
    "noEmit": true,
    "strict": true
  },
  "include": [
    ".wxt/wxt.d.ts",
    "entrypoints",
    "src",
    "wxt.config.ts",
    "tailwind.config.js",
    "postcss.config.js"
  ]
}
